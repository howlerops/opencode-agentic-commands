  "description": "OpenCode plugins and Pi extensions for agentic goal, planning, review, autoresearch, and AutoAgent workflows.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./goal": "./src/goal.mjs",
    "./autoresearch": "./src/autoresearch.mjs",
    "./autoagent": "./src/autoagent.mjs",
    "./ultrawork": "./src/ultrawork.mjs",
    "./ultraplan": "./src/ultraplan.mjs",
    "./ultrareview": "./src/ultrareview.mjs"
  },
  "files": [
