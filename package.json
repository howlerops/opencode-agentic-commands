{
  "name": "opencode-agentic-commands",
  "version": "0.1.0",
  "description": "OpenCode plugins and Pi extensions for agentic planning, execution, review, research, orchestration, and remote portal workflows.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.mjs",
  "bin": {
    "opencode-agentic-commands": "./scripts/install-opencode.mjs",
    "opencode-agentic-commands-install": "./scripts/install-opencode.mjs",
    "opencode-bifrost": "./scripts/bifrost-runner.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./tyr": "./src/tyr.mjs",
    "./munin": "./src/munin.mjs",
    "./eitri": "./src/eitri.mjs",
    "./vidar": "./src/vidar.mjs",
    "./hugin": "./src/hugin.mjs",
    "./skuld": "./src/skuld.mjs",
    "./polaris": "./src/polaris.mjs",
    "./bifrost": "./src/bifrost.mjs"
  },
  "files": [
    "src",
    "pi",
    "docs/guide",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./pi/extensions"
    ],
    "prompts": [
      "./pi/prompts"
    ]
  },
  "scripts": {
    "e2e:bifrost": "node scripts/bifrost-e2e-smoke.mjs",
    "install:hooks": "sh scripts/hooks/install.sh",
    "test": "node test/plugin.test.mjs && node test/pi-extension.test.mjs && node test/bifrost-proxy.test.mjs && node test/install-opencode.test.mjs && node test/install-guide.test.mjs"
  },
  "keywords": [
    "opencode",
    "pi-package",
    "pi-extension",
    "plugin",
    "baro",
    "tyr",
    "munin",
    "eitri",
    "vidar",
    "hugin",
    "skuld",
    "polaris",
    "bifrost",
    "agentic"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.17.11"
  }
}
